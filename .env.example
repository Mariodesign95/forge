# ============================================
# MARIFLIX — Private Configuration
# Copy this file to .env and fill in your keys
# ============================================

PORT=7000

# Your public URL (update when deploying to cloud)
ADDON_URL=http://localhost:7000

# Real-Debrid API Token — get from https://real-debrid.com/apitoken
RD_TOKEN=your_real_debrid_token_here

# Torbox API Token — get from https://torbox.app/settings
TB_TOKEN=your_torbox_token_here

# ============================================
# OPTIONAL: Prowlarr / Jackett
# ============================================
PROWLARR_URL=
PROWLARR_API_KEY=
JACKETT_URL=
JACKETT_API_KEY=
